{% extends 'layouts/admin.html.twig' %}

{% block title %}{{ is_new ? 'Nouvel utilisateur' : 'Éditer ' ~ user.firstName ~ ' ' ~ user.lastName }} - Les Mathu'Loire{% endblock %}

{% block body %}
<a href="{{ path('app_admin_user_index') }}" class="text-sm text-gray-500 hover:text-gray-700 mb-4 inline-block">&larr; Retour aux utilisateurs</a>

<h2 class="text-2xl font-bold text-gray-900 mb-6">{{ is_new ? 'Nouvel utilisateur' : 'Éditer : ' ~ user.firstName ~ ' ' ~ user.lastName }}</h2>

<div class="max-w-2xl">
    {{ form_start(form, { attr: { class: 'space-y-6' } }) }}

    <fieldset class="bg-white border border-gray-200 rounded-lg p-6">
        <legend class="text-sm font-semibold text-gray-900 px-1">Identité</legend>
        <div class="grid sm:grid-cols-2 gap-4 mt-3">
            <div>
                {{ form_label(form.firstName, null, { label_attr: { class: 'block text-sm font-medium text-gray-700 mb-1' } }) }}
                {{ form_widget(form.firstName, { attr: { class: 'w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-gray-900' } }) }}
                {{ form_errors(form.firstName) }}
            </div>
            <div>
                {{ form_label(form.lastName, null, { label_attr: { class: 'block text-sm font-medium text-gray-700 mb-1' } }) }}
                {{ form_widget(form.lastName, { attr: { class: 'w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-gray-900' } }) }}
                {{ form_errors(form.lastName) }}
            </div>
        </div>
    </fieldset>

    <fieldset class="bg-white border border-gray-200 rounded-lg p-6">
        <legend class="text-sm font-semibold text-gray-900 px-1">Connexion</legend>
        <div class="space-y-4 mt-3">
            <div>
                {{ form_label(form.email, null, { label_attr: { class: 'block text-sm font-medium text-gray-700 mb-1' } }) }}
                {{ form_widget(form.email, { attr: { class: 'w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-gray-900' } }) }}
                {{ form_errors(form.email) }}
            </div>
            <div>
                {{ form_label(form.plainPassword, null, { label_attr: { class: 'block text-sm font-medium text-gray-700 mb-1' } }) }}
                {{ form_widget(form.plainPassword, { attr: { class: 'w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-gray-900' } }) }}
                {{ form_errors(form.plainPassword) }}
                {% if not is_new %}
                    <p class="text-xs text-gray-400 mt-1">Laissez vide pour ne pas modifier le mot de passe.</p>
                {% endif %}
            </div>
        </div>
    </fieldset>

    <fieldset class="bg-white border border-gray-200 rounded-lg p-6">
        <legend class="text-sm font-semibold text-gray-900 px-1">Rôle</legend>
        <div class="mt-3 space-y-2">
            {% for child in form.roles %}
                <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
                    {{ form_widget(child, { attr: { class: 'rounded border-gray-300 text-gray-900 focus:ring-gray-900' } }) }}
                    {{ child.vars.label }}
                </label>
            {% endfor %}
            {{ form_errors(form.roles) }}
        </div>
    </fieldset>

    <button type="submit" class="px-6 py-2.5 bg-gray-900 text-white text-sm font-medium rounded-lg hover:bg-gray-800 transition-colors">
        {{ is_new ? 'Créer l\'utilisateur' : 'Enregistrer' }}
    </button>

    {{ form_end(form) }}
</div>
{% endblock %}
