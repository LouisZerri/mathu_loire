{% extends 'layouts/admin.html.twig' %}

{% block title %}Réservation #{{ reservation.id }} - Les Mathu'Loire{% endblock %}

{% block body %}
<div class="flex items-center justify-between mb-6">
    <div>
        <a href="{{ path('app_admin_dashboard') }}" class="text-sm text-gray-500 hover:text-gray-700">&larr; Retour au dashboard</a>
        <h2 class="text-2xl font-bold text-gray-900 mt-1">Réservation #{{ reservation.id }}</h2>
    </div>
    <div class="flex items-center gap-3">
        {% if reservation.status == 'validated' %}
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">Validée</span>
        {% elseif reservation.status == 'pending' %}
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-yellow-100 text-yellow-800">En attente</span>
        {% elseif reservation.status == 'modified' %}
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 text-blue-800">Modifiée</span>
        {% elseif reservation.status == 'cancelled' %}
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-red-100 text-red-800">Annulée</span>
        {% endif %}
    </div>
</div>

{% for flash in app.flashes('success') %}
    <div class="bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded-lg text-sm mb-6">{{ flash }}</div>
{% endfor %}

<div class="grid lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2">
        {{ form_start(form, { attr: { class: 'space-y-6' } }) }}

            {% include 'components/admin/reservation_form_representation.html.twig' with { form: form } %}
            {% include 'components/admin/reservation_form_places.html.twig' with { form: form } %}
            {% include 'components/admin/reservation_form_contact.html.twig' with { form: form } %}
            {% include 'components/admin/reservation_form_comments.html.twig' with { form: form } %}

            <div class="flex items-center gap-4">
                <button type="submit" class="px-6 py-2.5 bg-gray-900 text-white text-sm font-medium rounded-lg hover:bg-gray-800 transition-colors">
                    Enregistrer
                </button>
            </div>

        {{ form_end(form) }}
    </div>

    <div class="space-y-6">
        {% include 'components/admin/reservation_sidebar.html.twig' with { reservation: reservation, total: total } %}
    </div>
</div>
{% endblock %}
