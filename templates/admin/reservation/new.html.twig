{% extends 'layouts/admin.html.twig' %}

{% block title %}Nouvelle réservation - Les Mathu'Loire{% endblock %}

{% block body %}
<a href="{{ path('app_admin_reservation_index') }}" class="text-sm text-gray-500 hover:text-gray-700 mb-4 inline-block">&larr; Retour aux réservations</a>

<h2 class="text-2xl font-bold text-gray-900 mb-6">Nouvelle réservation</h2>

{% for flash in app.flashes('error') %}
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm mb-6">{{ flash }}</div>
{% endfor %}

<div class="max-w-3xl">
    {{ form_start(form, { attr: { class: 'space-y-6' } }) }}

        {% include 'components/admin/reservation_form_representation.html.twig' with { form: form } %}
        {% include 'components/admin/reservation_form_places.html.twig' with { form: form } %}
        {% include 'components/admin/reservation_form_contact.html.twig' with { form: form } %}
        {% if form.paymentMethod is defined %}
        <fieldset class="bg-white border border-gray-200 rounded-lg p-6">
            <legend class="text-sm font-semibold text-gray-900 px-1">Encaissement</legend>
            <div class="mt-3">
                {{ form_label(form.paymentMethod, null, { label_attr: { class: 'block text-sm font-medium text-gray-700 mb-1' } }) }}
                {{ form_widget(form.paymentMethod, { attr: { class: 'w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-gray-900' } }) }}
                <p class="text-xs text-gray-400 mt-1">Sélectionnez le mode de paiement si le spectateur paie maintenant. Sinon, laissez "Pas de paiement immédiat".</p>
            </div>
        </fieldset>
        {% endif %}
        {% include 'components/admin/reservation_form_comments.html.twig' with { form: form } %}

        <div class="flex items-center gap-4">
            <button type="submit" class="px-6 py-2.5 bg-gray-900 text-white text-sm font-medium rounded-lg hover:bg-gray-800 transition-colors">
                Créer la réservation
            </button>
            <a href="{{ path('app_admin_reservation_index') }}" class="text-sm text-gray-500 hover:text-gray-700">Annuler</a>
        </div>

    {{ form_end(form) }}
</div>
{% endblock %}
