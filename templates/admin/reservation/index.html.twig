{% extends 'layouts/admin.html.twig' %}

{% block title %}Réservations - Les Mathu'Loire{% endblock %}

{% block body %}
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
    <h2 class="text-2xl font-bold text-gray-900">Réservations</h2>

    <div class="flex items-center gap-3 flex-wrap">
        <form method="get" class="flex items-center gap-2">
            <label class="text-sm text-gray-500">Saison :</label>
            <select name="year" data-controller="auto-submit" data-action="change->auto-submit#submit" class="px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-gray-900">
                {% for year in availableYears %}
                    <option value="{{ year }}" {{ year == selectedYear ? 'selected' : '' }}>{{ year }}</option>
                {% endfor %}
            </select>
        </form>

        <a href="{{ path('app_admin_reservation_new') }}" class="px-4 py-2 bg-gray-900 text-white text-sm font-medium rounded-lg hover:bg-gray-800 transition-colors whitespace-nowrap">
            Nouvelle réservation
        </a>
    </div>
</div>

{% for flash in app.flashes('success') %}
    <div class="bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded-lg text-sm mb-6">{{ flash }}</div>
{% endfor %}

{% include 'components/admin/reservation_filters.html.twig' with {
    representations: representations,
    currentRep: currentRep,
    currentStatus: currentStatus,
    currentSearch: currentSearch,
    selectedYear: selectedYear
} %}

{% include 'components/admin/reservation_table.html.twig' with {
    reservations: reservations,
    totalResults: totalResults,
    currentPage: currentPage,
    totalPages: totalPages,
    currentRep: currentRep,
    currentStatus: currentStatus,
    currentSearch: currentSearch,
    selectedYear: selectedYear
} %}

{% if cancelledReservations|length > 0 %}
<h3 class="text-lg font-semibold text-gray-900 mt-10 mb-4">Réservations annulées</h3>

<div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead>
                <tr class="bg-gray-50 text-left text-xs text-gray-500 uppercase tracking-wide">
                    <th class="px-4 py-3">N°</th>
                    <th class="px-4 py-3">Nom</th>
                    <th class="px-4 py-3">Prénom</th>
                    <th class="px-4 py-3">Spectacle</th>
                    <th class="px-4 py-3">Date</th>
                    <th class="px-4 py-3 text-center">Ad.</th>
                    <th class="px-4 py-3 text-center">Enf.</th>
                    <th class="px-4 py-3 text-center">Inv.</th>
                    <th class="px-4 py-3 text-center">PMR</th>
                    <th class="px-4 py-3"></th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                {% for reservation in cancelledReservations %}
                <tr class="hover:bg-gray-50">
                    <td class="px-4 py-3 text-gray-400">{{ reservation.id }}</td>
                    <td class="px-4 py-3 text-gray-500">{{ reservation.spectatorLastName|upper }}</td>
                    <td class="px-4 py-3 text-gray-500">{{ reservation.spectatorFirstName }}</td>
                    <td class="px-4 py-3 text-gray-500">{{ reservation.representation.show.title }}</td>
                    <td class="px-4 py-3 text-gray-500 whitespace-nowrap">{{ reservation.representation.datetime|format_datetime(pattern='d MMM yyyy HH:mm', locale='fr', timezone='Europe/Paris') }}</td>
                    <td class="px-4 py-3 text-center text-gray-500">{{ reservation.nbAdults }}</td>
                    <td class="px-4 py-3 text-center text-gray-500">{{ reservation.nbChildren }}</td>
                    <td class="px-4 py-3 text-center text-gray-500">{{ reservation.nbInvitations }}</td>
                    <td class="px-4 py-3 text-center">
                        {% if reservation.isPMR %}
                            <span class="text-blue-600">Oui</span>
                        {% else %}
                            <span class="text-gray-400">-</span>
                        {% endif %}
                    </td>
                    <td class="px-4 py-3">
                        <a href="{{ path('app_admin_reservation_edit', { id: reservation.id }) }}" class="text-xs text-gray-500 hover:text-gray-900">Voir</a>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}
{% endblock %}
