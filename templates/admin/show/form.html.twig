{% extends 'layouts/admin.html.twig' %}

{% block title %}{{ is_new ? 'Nouveau spectacle' : 'Éditer ' ~ show.title }} - Les Mathu'Loire{% endblock %}

{% block body %}
<a href="{{ path('app_admin_show_index') }}" class="text-sm text-gray-500 hover:text-gray-700 mb-4 inline-block">&larr; Retour aux spectacles</a>

<h2 class="text-2xl font-bold text-gray-900 mb-6">{{ is_new ? 'Nouveau spectacle' : 'Éditer : ' ~ show.title }}</h2>

<div class="max-w-2xl">
    {{ form_start(form, { attr: { class: 'space-y-6' } }) }}

    <fieldset class="bg-white border border-gray-200 rounded-lg p-6">
        <div class="space-y-4">
            <div>
                {{ form_label(form.title, null, { label_attr: { class: 'block text-sm font-medium text-gray-700 mb-1' } }) }}
                {{ form_widget(form.title, { attr: { class: 'w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-gray-900' } }) }}
                {{ form_errors(form.title) }}
            </div>

            <div>
                {{ form_label(form.description, null, { label_attr: { class: 'block text-sm font-medium text-gray-700 mb-1' } }) }}
                {{ form_widget(form.description, { attr: { class: 'w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-gray-900' } }) }}
            </div>
        </div>
    </fieldset>

    <button type="submit" class="px-6 py-2.5 bg-gray-900 text-white text-sm font-medium rounded-lg hover:bg-gray-800 transition-colors">
        {{ is_new ? 'Créer le spectacle' : 'Enregistrer' }}
    </button>

    {{ form_end(form) }}
</div>
{% endblock %}
