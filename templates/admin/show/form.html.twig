{% extends 'layouts/admin.html.twig' %}

{% block title %}{{ is_new ? 'Nouveau spectacle' : 'Éditer ' ~ show.title }} - Les Mathu'Loire{% endblock %}

{% block body %}
<a href="{{ path('app_admin_show_index') }}" class="text-sm text-gray-500 hover:text-gray-700 mb-4 inline-block">&larr; Retour aux spectacles</a>

<h2 class="text-2xl font-bold text-gray-900 mb-6">{{ is_new ? 'Nouveau spectacle' : 'Éditer : ' ~ show.title }}</h2>

<div class="max-w-3xl">
    {{ form_start(form, { attr: { class: 'space-y-6', enctype: 'multipart/form-data' } }) }}

    <fieldset class="bg-white border border-gray-200 rounded-lg p-6">
        <legend class="text-sm font-semibold text-gray-900 px-1">Informations générales</legend>
        <div class="space-y-4 mt-3">
            <div>
                {{ form_label(form.title, null, { label_attr: { class: 'block text-sm font-medium text-gray-700 mb-1' } }) }}
                {{ form_widget(form.title, { attr: { class: 'w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-gray-900' } }) }}
                {{ form_errors(form.title) }}
            </div>

            <div>
                {{ form_label(form.description, null, { label_attr: { class: 'block text-sm font-medium text-gray-700 mb-1' } }) }}
                {{ form_widget(form.description, { attr: { class: 'w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-gray-900' } }) }}
            </div>

            <div>
                {{ form_label(form.synopsis, null, { label_attr: { class: 'block text-sm font-medium text-gray-700 mb-1' } }) }}
                {{ form_widget(form.synopsis, { attr: { class: 'w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-gray-900' } }) }}
            </div>
        </div>
    </fieldset>

    <fieldset class="bg-white border border-gray-200 rounded-lg p-6">
        <legend class="text-sm font-semibold text-gray-900 px-1">Équipe & Durée</legend>
        <div class="grid sm:grid-cols-3 gap-4 mt-3">
            <div>
                {{ form_label(form.author, null, { label_attr: { class: 'block text-sm font-medium text-gray-700 mb-1' } }) }}
                {{ form_widget(form.author, { attr: { class: 'w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-gray-900' } }) }}
            </div>
            <div>
                {{ form_label(form.director, null, { label_attr: { class: 'block text-sm font-medium text-gray-700 mb-1' } }) }}
                {{ form_widget(form.director, { attr: { class: 'w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-gray-900' } }) }}
            </div>
            <div>
                {{ form_label(form.duration, null, { label_attr: { class: 'block text-sm font-medium text-gray-700 mb-1' } }) }}
                {{ form_widget(form.duration, { attr: { class: 'w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-gray-900' } }) }}
            </div>
        </div>
    </fieldset>

    <fieldset class="bg-white border border-gray-200 rounded-lg p-6">
        <legend class="text-sm font-semibold text-gray-900 px-1">Affiche</legend>
        <div class="mt-3">
            {% if show.imageName %}
                <div class="mb-4">
                    <img src="{{ asset('uploads/shows/' ~ show.imageName) }}" alt="{{ show.title }}" class="h-40 rounded-lg shadow-sm">
                </div>
            {% endif %}
            {{ form_label(form.imageFile, null, { label_attr: { class: 'block text-sm font-medium text-gray-700 mb-1' } }) }}
            {{ form_widget(form.imageFile, { attr: { class: 'w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-medium file:bg-gray-100 file:text-gray-700 hover:file:bg-gray-200' } }) }}
            {{ form_errors(form.imageFile) }}
            <p class="text-xs text-gray-400 mt-1">JPG, PNG ou WebP, max 5 Mo.</p>
        </div>
    </fieldset>

    <button type="submit" class="px-6 py-2.5 bg-gray-900 text-white text-sm font-medium rounded-lg hover:bg-gray-800 transition-colors">
        {{ is_new ? 'Créer le spectacle' : 'Enregistrer' }}
    </button>

    {{ form_end(form) }}
</div>
{% endblock %}
