{% extends 'layouts/admin.html.twig' %}

{% block title %}Dashboard - Les Mathu'Loire{% endblock %}

{% block body %}
<h2 class="text-2xl font-bold text-gray-900 mb-6">Dashboard</h2>

{% include 'components/admin/season_stats.html.twig' with { stats: seasonStats, repStats: repStats } %}

{% set chartLabels = [] %}
{% set chartFillRates = [] %}
{% set chartRevenues = [] %}
{% set chartPlaces = [] %}
{% set chartCapacities = [] %}
{% for rep in repStats %}
    {% set chartLabels = chartLabels|merge([rep.showTitle ~ ' ' ~ rep.datetime|format_datetime(pattern='d/MM', locale='fr', timezone='Europe/Paris')]) %}
    {% set chartFillRates = chartFillRates|merge([rep.fillRate]) %}
    {% set chartRevenues = chartRevenues|merge([rep.revenue]) %}
    {% set chartPlaces = chartPlaces|merge([rep.totalPlaces]) %}
    {% set chartCapacities = chartCapacities|merge([rep.venueCapacity]) %}
{% endfor %}

<div data-controller="dashboard-charts"
     data-dashboard-charts-labels-value="{{ chartLabels|json_encode }}"
     data-dashboard-charts-fill-rates-value="{{ chartFillRates|json_encode }}"
     data-dashboard-charts-revenues-value="{{ chartRevenues|json_encode }}"
     data-dashboard-charts-places-value="{{ chartPlaces|json_encode }}"
     data-dashboard-charts-capacities-value="{{ chartCapacities|json_encode }}"
     data-dashboard-charts-adults-value="{{ seasonStats.totalAdults }}"
     data-dashboard-charts-children-value="{{ seasonStats.totalChildren }}"
     data-dashboard-charts-invitations-value="{{ seasonStats.totalInvitations }}">

    <div class="grid lg:grid-cols-2 gap-6 mb-8">
        <div class="bg-white border border-gray-200 rounded-lg p-6">
            <h3 class="text-sm font-semibold text-gray-900 mb-4">Remplissage par séance</h3>
            <div style="height: 250px;">
                <canvas id="chartFillRate"></canvas>
            </div>
        </div>

        <div class="bg-white border border-gray-200 rounded-lg p-6">
            <h3 class="text-sm font-semibold text-gray-900 mb-4">Recettes par séance</h3>
            <div style="height: 250px;">
                <canvas id="chartRevenue"></canvas>
            </div>
        </div>
    </div>

    <div class="grid lg:grid-cols-2 gap-6 mb-8">
        <div class="bg-white border border-gray-200 rounded-lg p-6">
            <h3 class="text-sm font-semibold text-gray-900 mb-4">Répartition des spectateurs</h3>
            <div style="height: 250px;">
                <canvas id="chartSpectators"></canvas>
            </div>
        </div>

        <div class="bg-white border border-gray-200 rounded-lg p-6">
            <h3 class="text-sm font-semibold text-gray-900 mb-4">Places par séance</h3>
            <div style="height: 250px;">
                <canvas id="chartPlaces"></canvas>
            </div>
        </div>
    </div>
</div>

{% include 'components/admin/representation_stats.html.twig' with { repStats: repStats } %}
{% endblock %}
