{% extends 'layouts/admin.html.twig' %}

{% block title %}Dashboard - Les Mathu'Loire{% endblock %}

{% block body %}
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
    <h2 class="text-2xl font-bold text-gray-900">Dashboard</h2>

    <form method="get" class="flex items-center gap-3">
        <label class="text-sm text-gray-500">Saison :</label>
        <select name="year"
                data-controller="auto-submit"
                data-action="change->auto-submit#submit"
                data-auto-submit-fade-target-value="#dashboard-content"
                class="px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-gray-900">
            {% for year in availableYears %}
                <option value="{{ year }}" {{ year == selectedYear ? 'selected' : '' }}>{{ year }}</option>
            {% endfor %}
        </select>
    </form>
</div>

<div id="dashboard-content" class="animate-fade-in">

{% if repStats|length > 0 %}

{% include 'components/admin/season_stats.html.twig' with { stats: seasonStats, repStats: repStats } %}

{% set chartLabels = [] %}
{% set chartFillRates = [] %}
{% for rep in repStats %}
    {% set chartLabels = chartLabels|merge([rep.showTitle ~ ' ' ~ rep.datetime|format_datetime(pattern='d/MM', locale='fr', timezone='Europe/Paris')]) %}
    {% set chartFillRates = chartFillRates|merge([rep.fillRate]) %}
{% endfor %}

<div data-controller="dashboard-charts"
     data-dashboard-charts-labels-value="{{ chartLabels|json_encode }}"
     data-dashboard-charts-fill-rates-value="{{ chartFillRates|json_encode }}"
     data-dashboard-charts-adults-value="{{ seasonStats.totalAdults }}"
     data-dashboard-charts-children-value="{{ seasonStats.totalChildren }}"
     data-dashboard-charts-invitations-value="{{ seasonStats.totalInvitations }}"
     data-dashboard-charts-city-labels-value="{{ cityStats|map(s => s.city)|json_encode }}"
     data-dashboard-charts-city-values-value="{{ cityStats|map(s => s.totalPlaces)|json_encode }}"
     data-dashboard-charts-show-labels-value="{{ revenueByShow|map(s => s.showTitle)|json_encode }}"
     data-dashboard-charts-show-revenues-value="{{ revenueByShow|map(s => s.revenue)|json_encode }}">

    <div class="grid md:grid-cols-2 gap-4 sm:gap-6 mb-6 sm:mb-8" data-controller="reveal">
        <div class="reveal bg-white border border-gray-200 rounded-lg p-4 sm:p-6 min-w-0 overflow-hidden">
            <h3 class="text-sm font-semibold text-gray-900 mb-4">Remplissage par séance</h3>
            <div class="h-48 sm:h-56 lg:h-64">
                <canvas id="chartFillRate"></canvas>
            </div>
        </div>

        {% if cityStats|length > 0 %}
        <div class="reveal bg-white border border-gray-200 rounded-lg p-4 sm:p-6 min-w-0 overflow-hidden">
            <h3 class="text-sm font-semibold text-gray-900 mb-4">Provenance des spectateurs</h3>
            <div class="h-48 sm:h-56 lg:h-64">
                <canvas id="chartCities"></canvas>
            </div>
        </div>
        {% endif %}
    </div>

    <div class="grid md:grid-cols-2 gap-4 sm:gap-6 mb-6 sm:mb-8" data-controller="reveal">
        <div class="reveal bg-white border border-gray-200 rounded-lg p-4 sm:p-6 min-w-0 overflow-hidden">
            <h3 class="text-sm font-semibold text-gray-900 mb-4">Répartition des spectateurs</h3>
            <div class="h-48 sm:h-56 lg:h-64">
                <canvas id="chartSpectators"></canvas>
            </div>
        </div>

        {% if revenueByShow|length > 0 %}
        <div class="reveal bg-white border border-gray-200 rounded-lg p-4 sm:p-6 min-w-0 overflow-hidden">
            <h3 class="text-sm font-semibold text-gray-900 mb-4">Recettes par spectacle</h3>
            <div class="h-48 sm:h-56 lg:h-64">
                <canvas id="chartShowRevenue"></canvas>
            </div>
        </div>
        {% endif %}
    </div>

</div>

{% include 'components/admin/representation_stats.html.twig' with { repStats: repStats } %}

{% else %}

<div class="mt-12 max-w-md mx-auto text-center">
    <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-gray-100 mb-4">
        <svg class="w-7 h-7 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
    </div>
    <h3 class="text-base font-semibold text-gray-900 mb-2">Aucune donnée pour {{ selectedYear }}</h3>
    <p class="text-sm text-gray-500">Aucune réservation validée n'a été trouvée pour cette saison. Les statistiques apparaîtront dès que des réservations seront enregistrées.</p>
</div>

{% endif %}

</div>
{% endblock %}
