{% extends 'layouts/admin.html.twig' %}

{% block title %}Plan de salle - Les Mathu'Loire{% endblock %}

{% block body %}
<div id="seatplan-root"
     data-representations='{{ representations|map(r => { id: r.id, label: r.show.title ~ " — " ~ r.datetime|format_datetime(pattern="EEE d MMM yyyy HH:mm", locale="fr", timezone="Europe/Paris")|capitalize })|json_encode|e('html_attr') }}'
     data-preselected-representation="{{ preselectedRepresentationId }}"
     data-preselected-reservation="{{ preselectedReservationId }}"></div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('seatplan') }}
{% endblock %}
