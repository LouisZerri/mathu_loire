<fieldset class="bg-white border border-gray-200 rounded-lg p-6">
    <legend class="text-sm font-semibold text-gray-900 px-1">Représentation & Statut</legend>

    <div class="grid sm:grid-cols-2 gap-4 mt-3">
        <div>
            {{ form_label(form.representation, null, { label_attr: { class: 'block text-sm font-medium text-gray-700 mb-1' } }) }}
            {{ form_widget(form.representation, { attr: { class: 'w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-gray-900' } }) }}
            {{ form_errors(form.representation) }}
        </div>

        <div>
            {{ form_label(form.status, null, { label_attr: { class: 'block text-sm font-medium text-gray-700 mb-1' } }) }}
            {{ form_widget(form.status, { attr: { class: 'w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-gray-900' } }) }}
            {{ form_errors(form.status) }}
        </div>
    </div>
</fieldset>
