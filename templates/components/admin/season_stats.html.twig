<div class="grid sm:grid-cols-2 xl:grid-cols-4 gap-4 mb-8">
    <div class="bg-white border border-gray-200 rounded-lg p-5 min-w-0">
        <div class="text-xs text-gray-400 uppercase tracking-wide">Spectateurs</div>
        <div class="text-3xl font-bold text-gray-900 mt-1">{{ stats.totalSpectators }}</div>
        <div class="text-xs text-gray-500 mt-1 truncate">
            {{ stats.totalAdults }} ad. · {{ stats.totalChildren }} enf.
            {% if stats.totalInvitations > 0 %} · {{ stats.totalInvitations }} invit.{% endif %}
        </div>
    </div>

    <div class="bg-white border border-gray-200 rounded-lg p-5 min-w-0">
        <div class="text-xs text-gray-400 uppercase tracking-wide">Réservations</div>
        <div class="text-3xl font-bold text-gray-900 mt-1">{{ stats.totalReservations }}</div>
        <div class="text-xs text-gray-500 mt-1">validées</div>
    </div>

    <div class="bg-white border border-gray-200 rounded-lg p-5 min-w-0">
        <div class="text-xs text-gray-400 uppercase tracking-wide">Recettes</div>
        <div class="text-2xl sm:text-3xl font-bold text-gray-900 mt-1 truncate">{{ stats.totalRevenue|number_format(0, ',', ' ') }} €</div>
        <div class="text-xs text-gray-500 mt-1">saison en cours</div>
    </div>

    <div class="bg-white border border-gray-200 rounded-lg p-5 min-w-0">
        <div class="text-xs text-gray-400 uppercase tracking-wide">Séances</div>
        <div class="text-3xl font-bold text-gray-900 mt-1">{{ repStats|length }}</div>
        <div class="text-xs text-gray-500 mt-1">avec réservations</div>
    </div>
</div>
