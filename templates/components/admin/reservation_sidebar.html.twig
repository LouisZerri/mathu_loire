<div class="bg-white border border-gray-200 rounded-lg p-5">
    <h3 class="text-sm font-semibold text-gray-900 mb-4">Résumé</h3>

    <div class="space-y-3 text-sm">
        <div class="flex justify-between">
            <span class="text-gray-500">Total places</span>
            <span class="font-medium text-gray-900">{{ reservation.nbAdults + reservation.nbChildren + reservation.nbInvitations }}</span>
        </div>
        <div class="flex justify-between">
            <span class="text-gray-500">Adultes</span>
            <span class="text-gray-900">{{ reservation.nbAdults }} x {{ reservation.representation.adultPrice|number_format(2, ',', ' ') }} €</span>
        </div>
        <div class="flex justify-between">
            <span class="text-gray-500">Enfants</span>
            <span class="text-gray-900">{{ reservation.nbChildren }} x {{ reservation.representation.childPrice|number_format(2, ',', ' ') }} €</span>
        </div>
        {% if reservation.nbInvitations > 0 %}
        <div class="flex justify-between">
            <span class="text-gray-500">Invitations</span>
            <span class="text-gray-900">{{ reservation.nbInvitations }}</span>
        </div>
        {% endif %}
        <div class="flex justify-between border-t border-gray-100 pt-3">
            <span class="font-semibold text-gray-900">Total</span>
            <span class="font-bold text-gray-900 text-lg">{{ total|number_format(2, ',', ' ') }} €</span>
        </div>

    </div>
</div>

{% if reservation.status == 'validated' %}
{% set paid = 0 %}
{% for p in reservation.payments %}{% if p.type == 'payment' %}{% set paid = paid + p.amount %}{% endif %}{% endfor %}
{% set remaining = total - paid %}

<div class="bg-white border border-gray-200 rounded-lg p-5">
    <h3 class="text-sm font-semibold text-gray-900 mb-3">Paiements</h3>

    {% if reservation.payments|filter(p => p.type == 'payment')|length > 0 %}
    <div class="space-y-2 mb-3">
        {% for payment in reservation.payments %}
        {% if payment.type == 'payment' %}
        <div class="flex items-center justify-between text-sm bg-gray-50 rounded px-3 py-2">
            <div>
                <span class="font-medium text-gray-900">{{ payment.amount|number_format(2, ',', ' ') }} €</span>
                <span class="text-gray-400">·</span>
                <span class="text-gray-500">{{ payment.method }}</span>
            </div>
            {% if payment.method != 'helloasso' %}
            <div class="flex items-center gap-2">
                <button type="button" onclick="document.getElementById('edit-payment-{{ payment.id }}').classList.toggle('hidden')" class="text-xs text-blue-500 hover:text-blue-700">Modifier</button>
                <form method="post" action="{{ path('app_admin_reservation_delete_payment', { id: reservation.id, paymentId: payment.id }) }}" onsubmit="return confirm('Supprimer ce paiement ?')">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_payment_' ~ payment.id) }}">
                    <button type="submit" class="text-xs text-red-500 hover:text-red-700">Suppr.</button>
                </form>
            </div>
            {% endif %}
        </div>
        {% if payment.method != 'helloasso' %}
        <form id="edit-payment-{{ payment.id }}" method="post" action="{{ path('app_admin_reservation_edit_payment', { id: reservation.id, paymentId: payment.id }) }}" class="hidden bg-white border border-gray-200 rounded px-3 py-2 mt-1">
            <input type="hidden" name="_token" value="{{ csrf_token('edit_payment_' ~ payment.id) }}">
            <div class="grid grid-cols-2 gap-2 mb-2">
                <input type="number" name="amount" step="0.01" min="0.01" value="{{ payment.amount }}" class="px-2 py-1 border border-gray-300 rounded text-xs">
                <select name="method" class="px-2 py-1 border border-gray-300 rounded text-xs">
                    <option value="especes" {{ payment.method == 'especes' ? 'selected' : '' }}>Espèces</option>
                    <option value="cheque" {{ payment.method == 'cheque' ? 'selected' : '' }}>Chèque</option>
                    <option value="cb" {{ payment.method == 'cb' ? 'selected' : '' }}>CB</option>
                </select>
            </div>
            <button type="submit" class="w-full px-2 py-1 bg-blue-600 text-white text-xs rounded hover:bg-blue-700">Enregistrer</button>
        </form>
        {% endif %}
        {% endif %}
        {% endfor %}
    </div>
    {% endif %}

    <div class="flex justify-between text-sm mb-3 {{ remaining > 0 ? 'text-amber-700' : 'text-green-700' }} font-semibold">
        <span>{% if remaining > 0 %}Reste à encaisser{% else %}Entièrement payé{% endif %}</span>
        <span>{% if remaining > 0 %}{{ remaining|number_format(2, ',', ' ') }} €{% else %}✓{% endif %}</span>
    </div>

    {% if remaining > 0 %}
    <form method="post" action="{{ path('app_admin_reservation_add_payment', { id: reservation.id }) }}" class="border-t border-gray-100 pt-3">
        <input type="hidden" name="_token" value="{{ csrf_token('add_payment_' ~ reservation.id) }}">
        <div class="grid grid-cols-2 gap-2 mb-2">
            <input type="number" name="amount" step="0.01" min="0.01" max="{{ remaining }}" value="{{ remaining|number_format(2, '.', '') }}"
                   class="px-2 py-1.5 border border-gray-300 rounded text-sm focus:outline-none focus:ring-2 focus:ring-gray-900" placeholder="Montant">
            <select name="method" class="px-2 py-1.5 border border-gray-300 rounded text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
                <option value="especes">Espèces</option>
                <option value="cheque">Chèque</option>
                <option value="cb">CB</option>
            </select>
        </div>
        <button type="submit" class="w-full px-3 py-1.5 bg-green-600 text-white text-xs font-medium rounded hover:bg-green-700 transition-colors">
            Encaisser
        </button>
    </form>
    {% endif %}
</div>
{% endif %}

<div class="bg-white border border-gray-200 rounded-lg p-5">
    <h3 class="text-sm font-semibold text-gray-900 mb-4">Historique</h3>

    <div class="space-y-2 text-sm">
        <div>
            <span class="text-gray-500">Enregistrée le</span>
            <p class="text-gray-900">{{ reservation.createdAt|format_datetime(pattern='EEEE d MMMM yyyy à HH:mm', locale='fr', timezone='Europe/Paris')|capitalize }}</p>
        </div>
        {% if reservation.updatedAt %}
        <div>
            <span class="text-gray-500">Dernière modification</span>
            <p class="text-gray-900">{{ reservation.updatedAt|format_datetime(pattern='EEEE d MMMM yyyy à HH:mm', locale='fr', timezone='Europe/Paris')|capitalize }}</p>
        </div>
        {% endif %}
        {% if reservation.createdBy %}
        <div>
            <span class="text-gray-500">Créée par</span>
            <p class="text-gray-900">{{ reservation.createdBy.firstName }} {{ reservation.createdBy.lastName }}</p>
        </div>
        {% endif %}
    </div>
</div>

<div class="bg-white border border-gray-200 rounded-lg p-5">
    <h3 class="text-sm font-semibold text-gray-900 mb-4">Actions</h3>

    <div class="space-y-2">
        <a href="{{ path('app_admin_seatplan', { representation: reservation.representation.id, reservation: reservation.id }) }}"
           class="block w-full px-4 py-2 bg-gray-900 text-white text-sm rounded-lg hover:bg-gray-800 transition-colors text-center">
            Placer dans le plan de salle
        </a>

        <form method="post" action="{{ path('app_admin_reservation_resend_email', { id: reservation.id }) }}">
            <input type="hidden" name="_token" value="{{ csrf_token('resend_email_' ~ reservation.id) }}">
            <button type="submit" class="w-full px-4 py-2 border border-gray-300 text-sm rounded-lg text-gray-700 hover:bg-gray-50 transition-colors">
                Renvoyer l'email de confirmation
            </button>
        </form>

        <a href="{{ path('app_admin_reservation_print', { id: reservation.id }) }}" target="_blank"
           class="block w-full px-4 py-2 border border-gray-300 text-sm rounded-lg text-gray-700 hover:bg-gray-50 transition-colors text-center">
            Imprimer les billets (80mm)
        </a>

        {% if reservation.status != 'cancelled' %}
            {% if reservation.payments|length > 0 %}
            <form method="post" action="{{ path('app_admin_reservation_refund', { id: reservation.id }) }}" onsubmit="return confirm('Annuler cette réservation et rembourser le spectateur ? Cette action est irréversible.')">
                <input type="hidden" name="_token" value="{{ csrf_token('refund_' ~ reservation.id) }}">
                <button type="submit" class="w-full px-4 py-2 bg-red-50 border border-red-200 text-sm rounded-lg text-red-700 hover:bg-red-100 transition-colors">
                    Annuler et rembourser
                </button>
            </form>
            {% else %}
            <form method="post" action="{{ path('app_admin_reservation_cancel', { id: reservation.id }) }}" onsubmit="return confirm('Annuler cette réservation ? Cette action est irréversible.')">
                <input type="hidden" name="_token" value="{{ csrf_token('cancel_' ~ reservation.id) }}">
                <button type="submit" class="w-full px-4 py-2 bg-red-50 border border-red-200 text-sm rounded-lg text-red-700 hover:bg-red-100 transition-colors">
                    Annuler la réservation
                </button>
            </form>
            {% endif %}
        {% endif %}
    </div>
</div>
