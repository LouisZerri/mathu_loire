<fieldset class="bg-white border border-gray-200 rounded-lg p-6">
    <legend class="text-sm font-semibold text-gray-900 px-1">Commentaires</legend>

    <div class="space-y-4 mt-3">
        <div>
            {{ form_label(form.spectatorComment, null, { label_attr: { class: 'block text-sm font-medium text-gray-700 mb-1' } }) }}
            {{ form_widget(form.spectatorComment, { attr: { class: 'w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-gray-900' } }) }}
        </div>

        <div>
            {{ form_label(form.adminComment, null, { label_attr: { class: 'block text-sm font-medium text-gray-700 mb-1' } }) }}
            {{ form_widget(form.adminComment, { attr: { class: 'w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-gray-900' } }) }}
        </div>
    </div>
</fieldset>
