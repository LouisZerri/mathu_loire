<fieldset class="bg-white border border-gray-200 rounded-lg p-6">
    <legend class="text-sm font-semibold text-gray-900 px-1">Places</legend>

    <div class="grid sm:grid-cols-4 gap-4 mt-3">
        <div>
            {{ form_label(form.nbAdults, null, { label_attr: { class: 'block text-sm font-medium text-gray-700 mb-1' } }) }}
            {{ form_widget(form.nbAdults, { attr: { class: 'w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-gray-900' } }) }}
            {{ form_errors(form.nbAdults) }}
        </div>

        <div>
            {{ form_label(form.nbChildren, null, { label_attr: { class: 'block text-sm font-medium text-gray-700 mb-1' } }) }}
            {{ form_widget(form.nbChildren, { attr: { class: 'w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-gray-900' } }) }}
            {{ form_errors(form.nbChildren) }}
        </div>

        <div>
            {{ form_label(form.nbInvitations, null, { label_attr: { class: 'block text-sm font-medium text-gray-700 mb-1' } }) }}
            {{ form_widget(form.nbInvitations, { attr: { class: 'w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-gray-900' } }) }}
            {{ form_errors(form.nbInvitations) }}
        </div>

        {% if form.nbGroups is defined %}
        <div>
            {{ form_label(form.nbGroups, null, { label_attr: { class: 'block text-sm font-medium text-gray-700 mb-1' } }) }}
            {{ form_widget(form.nbGroups, { attr: { class: 'w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-gray-900' } }) }}
            {{ form_errors(form.nbGroups) }}
        </div>
        {% endif %}
    </div>

    <div class="mt-4">
        <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
            {{ form_widget(form.isPMR, { attr: { class: 'rounded border-gray-300 text-gray-900 focus:ring-gray-900' } }) }}
            Personne à mobilité réduite (PMR)
        </label>
    </div>
</fieldset>
