<form method="get" action="{{ path('app_admin_reservation_index') }}" class="flex flex-wrap items-end gap-4 mb-4">
    {% if selectedYear is defined %}
        <input type="hidden" name="year" value="{{ selectedYear }}">
    {% endif %}
    <div>
        <label class="block text-xs text-gray-500 mb-1">Représentation</label>
        <select name="representation" class="px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-gray-900">
            <option value="">Toutes</option>
            {% for rep in representations %}
                <option value="{{ rep.id }}" {{ currentRep and currentRep.id == rep.id ? 'selected' : '' }}>
                    {{ rep.show.title }} — {{ rep.datetime|format_datetime(pattern='d MMM yyyy HH:mm', locale='fr', timezone='Europe/Paris') }}
                </option>
            {% endfor %}
        </select>
    </div>

    <div>
        <label class="block text-xs text-gray-500 mb-1">Statut</label>
        <select name="status" class="px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-gray-900">
            <option value="">Tous</option>
            <option value="validated" {{ currentStatus == 'validated' ? 'selected' : '' }}>Validées</option>
            <option value="pending" {{ currentStatus == 'pending' ? 'selected' : '' }}>En attente</option>
            <option value="cancelled" {{ currentStatus == 'cancelled' ? 'selected' : '' }}>Annulées</option>
        </select>
    </div>

    <div class="flex items-center gap-3">
        <button type="submit" class="px-4 py-2 bg-gray-900 text-white text-sm rounded-md hover:bg-gray-800 transition-colors">
            Filtrer
        </button>

        {% if currentRep or currentStatus %}
            <a href="{{ path('app_admin_reservation_index') }}" class="text-sm text-gray-500 hover:text-gray-700">Réinitialiser</a>
        {% endif %}
    </div>
</form>
