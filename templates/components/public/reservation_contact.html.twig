<fieldset class="bg-white border border-gray-200 rounded-lg p-6">
    <legend class="text-lg font-semibold text-gray-900 px-1">Vos coordonnées</legend>

    <div class="grid sm:grid-cols-2 gap-6 mt-4">
        <div>
            {{ form_label(form.spectatorLastName, null, { label_attr: { class: 'block text-sm font-medium text-gray-700 mb-1' } }) }}
            {{ form_widget(form.spectatorLastName, { attr: { class: 'w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-gray-900' } }) }}
            {{ form_errors(form.spectatorLastName) }}
        </div>

        <div>
            {{ form_label(form.spectatorFirstName, null, { label_attr: { class: 'block text-sm font-medium text-gray-700 mb-1' } }) }}
            {{ form_widget(form.spectatorFirstName, { attr: { class: 'w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-gray-900' } }) }}
            {{ form_errors(form.spectatorFirstName) }}
        </div>

        <div>
            {{ form_label(form.spectatorCity, null, { label_attr: { class: 'block text-sm font-medium text-gray-700 mb-1' } }) }}
            {{ form_widget(form.spectatorCity, { attr: { class: 'w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-gray-900' } }) }}
            {{ form_errors(form.spectatorCity) }}
        </div>

        <div>
            {{ form_label(form.spectatorPhone, null, { label_attr: { class: 'block text-sm font-medium text-gray-700 mb-1' } }) }}
            {{ form_widget(form.spectatorPhone, { attr: { class: 'w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-gray-900' } }) }}
            {{ form_errors(form.spectatorPhone) }}
        </div>

        <div class="sm:col-span-2">
            {{ form_label(form.spectatorEmail, null, { label_attr: { class: 'block text-sm font-medium text-gray-700 mb-1' } }) }}
            {{ form_widget(form.spectatorEmail, { attr: { class: 'w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-gray-900' } }) }}
            {{ form_errors(form.spectatorEmail) }}
        </div>

        <div class="sm:col-span-2">
            {{ form_label(form.spectatorComment, null, { label_attr: { class: 'block text-sm font-medium text-gray-700 mb-1' } }) }}
            {{ form_widget(form.spectatorComment, { attr: { class: 'w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-gray-900' } }) }}
        </div>
    </div>
</fieldset>
