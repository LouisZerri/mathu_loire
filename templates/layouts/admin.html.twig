{% extends 'base.html.twig' %}

{% block layout %}
    <div class="min-h-screen bg-gray-100" data-controller="admin-sidebar">
        <div class="lg:hidden bg-white border-b border-gray-200 px-4 py-3 flex items-center justify-between">
            <a href="{{ path('app_admin_dashboard') }}">
                <img src="{{ asset('images/matu-loire-logo-couleur-sans-fond2-11.png') }}" alt="Les Mathu'Loire" class="h-8">
            </a>
            <button data-action="admin-sidebar#toggle" class="p-2 text-gray-600 hover:text-gray-900">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                </svg>
            </button>
        </div>

        <div class="flex">
            <div data-admin-sidebar-target="sidebar" class="hidden lg:block">
                {% include 'components/admin/sidebar.html.twig' %}
            </div>

            <div class="flex-1 flex flex-col min-h-screen lg:min-h-0 min-w-0">
                <div class="hidden lg:block">
                    {% include 'components/admin/topbar.html.twig' %}
                </div>

                <main class="flex-1 p-4 sm:p-6 min-w-0">
                    {% block body %}{% endblock %}
                </main>
            </div>
        </div>
    </div>
{% endblock %}
