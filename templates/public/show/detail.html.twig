{% extends 'layouts/public.html.twig' %}

{% block title %}{{ show.title }} - Les Mathu'Loire{% endblock %}

{% block body %}
<section class="max-w-5xl mx-auto px-4 py-12">
    <a href="{{ path('app_home') }}" class="text-sm text-gray-500 hover:text-gray-700 mb-8 inline-block">&larr; Retour à l'accueil</a>

    <div class="grid md:grid-cols-5 gap-10">
        <div class="md:col-span-2">
            {% if show.imageName %}
                <img src="{{ asset('uploads/shows/' ~ show.imageName) }}"
                     alt="{{ show.title }}"
                     class="w-full rounded-lg shadow-lg">
            {% else %}
                <div class="w-full aspect-[2/3] bg-gray-200 rounded-lg flex items-center justify-center">
                    <span class="text-gray-400 text-sm">Pas d'affiche</span>
                </div>
            {% endif %}
        </div>

        <div class="md:col-span-3">
            <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-3">{{ show.title }}</h1>

            {% if show.description %}
                <p class="text-lg text-gray-500 mb-6">{{ show.description }}</p>
            {% endif %}

            <div class="flex flex-wrap gap-4 mb-8">
                {% if show.author %}
                <div class="flex items-center gap-2 text-sm text-gray-600">
                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                    <span>De <strong>{{ show.author }}</strong></span>
                </div>
                {% endif %}
                {% if show.director %}
                <div class="flex items-center gap-2 text-sm text-gray-600">
                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
                    <span>Mise en scène <strong>{{ show.director }}</strong></span>
                </div>
                {% endif %}
                {% if show.duration %}
                <div class="flex items-center gap-2 text-sm text-gray-600">
                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    <span>{{ show.duration }}</span>
                </div>
                {% endif %}
            </div>

            {% if show.synopsis %}
            <div class="mb-8">
                <h2 class="text-lg font-semibold text-gray-900 mb-3">Synopsis</h2>
                <p class="text-gray-600 leading-relaxed">{{ show.synopsis|nl2br }}</p>
            </div>
            {% endif %}

            <div class="bg-gray-50 rounded-lg p-5">
                <div class="flex items-center gap-2 text-sm text-gray-600 mb-1">
                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    <span><strong>Espace Lézin Moisseron</strong> — Salle des Fêtes</span>
                </div>
                <p class="text-sm text-gray-500 ml-6">50 Rue Port la Vallée, 49250 Saint-Mathurin-sur-Loire</p>
                <p class="text-xs text-gray-400 ml-6 mt-1">Ouverture de la billetterie 45 min avant le spectacle. Parking PMR disponible.</p>
            </div>
        </div>
    </div>

    {% if representations|length > 0 %}
    <div class="mt-10">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Prochaines dates</h2>

        {# Mobile : cards empilées #}
        <div class="sm:hidden space-y-3 reveal-stagger" data-controller="reveal">
            {% for rep in representations %}
                <div class="reveal bg-white border border-gray-200 rounded-lg p-4">
                    <div class="flex items-start justify-between gap-3 mb-3">
                        <div>
                            <div class="font-medium text-gray-900 capitalize">{{ rep.entity.datetime|format_datetime(pattern='EEEE d MMMM', locale='fr', timezone='Europe/Paris') }}</div>
                            <div class="text-sm text-gray-500">{{ rep.entity.datetime|format_datetime(pattern='HH:mm', locale='fr', timezone='Europe/Paris') }}</div>
                        </div>
                        {% if rep.isFull %}
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800 shrink-0">Complet</span>
                        {% elseif rep.remaining <= 20 %}
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800 shrink-0">{{ rep.remaining }} places</span>
                        {% else %}
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 shrink-0">Disponible</span>
                        {% endif %}
                    </div>
                    <div class="flex items-center justify-between">
                        <div class="text-xs text-gray-500">
                            {{ rep.entity.adultPrice|number_format(2, ',', ' ') }} € adulte · {{ rep.entity.childPrice|number_format(2, ',', ' ') }} € enfant
                        </div>
                        {% if not rep.isFull %}
                            <a href="{{ path('app_reservation_new', { id: rep.entity.id }) }}" class="bg-gray-900 text-white px-4 py-1.5 rounded text-sm font-medium hover:bg-gray-800 transition-colors">Réserver</a>
                        {% endif %}
                    </div>
                </div>
            {% endfor %}
        </div>

        {# Desktop : tableau #}
        <div class="hidden sm:block bg-white border border-gray-200 rounded-lg overflow-hidden">
            <table class="w-full text-sm">
                <thead>
                    <tr class="bg-gray-50 text-left text-xs text-gray-500 uppercase tracking-wide">
                        <th class="px-4 py-3">Date</th>
                        <th class="px-4 py-3">Heure</th>
                        <th class="px-4 py-3">Tarif adulte</th>
                        <th class="px-4 py-3">Tarif enfant</th>
                        <th class="px-4 py-3 text-center">Disponibilité</th>
                        <th class="px-4 py-3"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    {% for rep in representations %}
                    <tr class="hover:bg-gray-50">
                        <td class="px-4 py-3 font-medium text-gray-900">{{ rep.entity.datetime|format_datetime(pattern='EEEE d MMMM yyyy', locale='fr', timezone='Europe/Paris')|capitalize }}</td>
                        <td class="px-4 py-3 text-gray-600">{{ rep.entity.datetime|format_datetime(pattern='HH:mm', locale='fr', timezone='Europe/Paris') }}</td>
                        <td class="px-4 py-3 text-gray-600">{{ rep.entity.adultPrice|number_format(2, ',', ' ') }} €</td>
                        <td class="px-4 py-3 text-gray-600">{{ rep.entity.childPrice|number_format(2, ',', ' ') }} €</td>
                        <td class="px-4 py-3 text-center">
                            {% if rep.isFull %}
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">Complet</span>
                            {% elseif rep.remaining <= 20 %}
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">{{ rep.remaining }} places</span>
                            {% else %}
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Disponible</span>
                            {% endif %}
                        </td>
                        <td class="px-4 py-3 text-right">
                            {% if rep.isFull %}
                                <span class="text-sm text-gray-400">Complet</span>
                            {% else %}
                                <a href="{{ path('app_reservation_new', { id: rep.entity.id }) }}" class="inline-block bg-gray-900 text-white px-4 py-1.5 rounded text-sm font-medium hover:bg-gray-800 transition-colors">Réserver</a>
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% endif %}
</section>
{% endblock %}
