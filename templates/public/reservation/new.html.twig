{% extends 'layouts/public.html.twig' %}

{% block title %}Réserver - {{ representation.show.title }} - Les Mathu'Loire{% endblock %}

{% block body %}
<section class="max-w-3xl mx-auto px-4 py-12">
    <a href="{{ path('app_reservation_index') }}" class="text-sm text-gray-500 hover:text-gray-700 mb-6 inline-block">&larr; Retour à la billetterie</a>

    {% include 'components/public/reservation_header.html.twig' with { representation: representation } %}

    {% for flash in app.flashes('error') %}
        <div class="bg-red-50 text-red-700 px-4 py-3 rounded-lg text-sm mb-6">{{ flash }}</div>
    {% endfor %}

    {{ form_start(form, { attr: { class: 'space-y-8' } }) }}

        {% include 'components/public/reservation_places.html.twig' with { form: form, representation: representation } %}
        {% include 'components/public/reservation_contact.html.twig' with { form: form } %}

        <div class="pt-4">
            <button type="submit"
                    class="w-full bg-gray-900 text-white py-3 px-6 rounded-lg text-sm font-semibold hover:bg-gray-800 transition-colors">
                Confirmer la réservation
            </button>
        </div>

    {{ form_end(form) }}
</section>
{% endblock %}
