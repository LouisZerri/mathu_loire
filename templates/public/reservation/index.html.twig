{% extends 'layouts/public.html.twig' %}

{% block title %}Billetterie - Les Mathu'Loire{% endblock %}

{% block body %}
<section class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-semibold text-gray-900 mb-2">Billetterie</h1>
    <p class="text-gray-500 mb-10">Choisissez une représentation pour réserver vos places.</p>

    {% if representations|length > 0 %}
        <div class="space-y-3">
            {% for representation in representations %}
                {% include 'components/public/representation_card.html.twig' with { representation: representation } %}
            {% endfor %}
        </div>
    {% else %}
        <div class="text-center py-16 text-gray-500">
            <p class="text-lg">Aucune représentation disponible pour le moment.</p>
            <p class="mt-2 text-sm">Revenez bientôt pour découvrir notre prochaine saison.</p>
        </div>
    {% endif %}
</section>
{% endblock %}
