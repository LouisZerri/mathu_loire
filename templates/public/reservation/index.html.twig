{% extends 'layouts/public.html.twig' %}

{% block title %}Billetterie - Les Mathu'Loire{% endblock %}

{% block body %}
<section class="max-w-6xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-semibold text-gray-900 mb-2">Billetterie</h1>
    <p class="text-gray-500 mb-10">Choisissez un spectacle pour réserver vos places.</p>

    {% if grouped|length > 0 %}
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {% for group in grouped %}
                {% set show = group.show %}
                {% set reps = group.representations %}
                {% set nbDates = reps|length %}
                {% set nextRep = group.nextRep %}
                {% set allFull = group.allFull %}

                <a href="{{ path('app_show_detail', { id: show.id }) }}" class="bg-white border border-gray-200 rounded-lg overflow-hidden hover:shadow-md transition-shadow group flex flex-col relative">
                    {# Badge d'urgence en haut à gauche #}
                    {% if allFull %}
                        <span class="absolute top-3 left-3 z-10 px-2.5 py-1 bg-red-600 text-white text-xs font-semibold rounded-full shadow">Complet</span>
                    {% elseif nextRep.isAlmostFull %}
                        <span class="absolute top-3 left-3 z-10 px-2.5 py-1 bg-amber-500 text-white text-xs font-semibold rounded-full shadow">Dernières places !</span>
                    {% elseif nextRep.daysUntil is not null and nextRep.daysUntil <= 7 and nextRep.daysUntil >= 0 %}
                        <span class="absolute top-3 left-3 z-10 px-2.5 py-1 bg-gray-900 text-white text-xs font-semibold rounded-full shadow">
                            {% if nextRep.daysUntil == 0 %}Aujourd'hui
                            {% elseif nextRep.daysUntil == 1 %}Demain
                            {% else %}J-{{ nextRep.daysUntil }}{% endif %}
                        </span>
                    {% endif %}

                    <div class="aspect-[2/3] overflow-hidden bg-gray-100">
                        {% if show.imageName %}
                            <img src="{{ asset('uploads/shows/' ~ show.imageName) }}"
                                 alt="{{ show.title }}"
                                 class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300">
                        {% else %}
                            <div class="w-full h-full flex items-center justify-center text-gray-400 text-sm">Pas d'affiche</div>
                        {% endif %}
                    </div>

                    <div class="p-4 flex-1 flex flex-col">
                        <h2 class="font-semibold text-gray-900 group-hover:underline">{{ show.title }}</h2>
                        {% if show.author %}
                            <p class="text-xs text-gray-500 mt-0.5">De {{ show.author }}</p>
                        {% endif %}

                        {# Liste des prochaines dates (max 3) #}
                        <ul class="mt-3 space-y-1">
                            {% for r in reps|slice(0, 3) %}
                                <li class="flex items-center justify-between text-xs">
                                    <span class="text-gray-600 capitalize">
                                        {{ r.entity.datetime|format_datetime(pattern='EEE d MMM · HH:mm', locale='fr', timezone='Europe/Paris') }}
                                    </span>
                                    {% if r.isFull %}
                                        <span class="text-red-600 font-medium">Complet</span>
                                    {% elseif r.isAlmostFull %}
                                        <span class="text-amber-600 font-medium">{{ r.remaining }} place{{ r.remaining > 1 ? 's' : '' }}</span>
                                    {% else %}
                                        <span class="text-emerald-600 font-medium">Disponible</span>
                                    {% endif %}
                                </li>
                            {% endfor %}
                            {% if nbDates > 3 %}
                                <li class="text-xs text-gray-400">+ {{ nbDates - 3 }} autre{{ nbDates - 3 > 1 ? 's' : '' }}…</li>
                            {% endif %}
                        </ul>

                        <div class="mt-auto pt-3 flex items-center justify-between text-xs border-t border-gray-100">
                            <span class="text-gray-500">
                                {% if group.totalBooked >= 10 %}
                                    {{ group.totalBooked }} spectateurs ont déjà réservé
                                {% else %}
                                    à partir de {{ nextRep.entity.adultPrice }} €
                                {% endif %}
                            </span>
                            {% if allFull %}
                                <span class="text-red-600 font-medium">—</span>
                            {% else %}
                                <span class="text-gray-900 font-medium group-hover:translate-x-1 transition-transform">Réserver &rarr;</span>
                            {% endif %}
                        </div>
                    </div>
                </a>
            {% endfor %}
        </div>

        {% if totalPages > 1 %}
        <div class="flex items-center justify-center gap-2 mt-10">
            {% if currentPage > 1 %}
                <a href="{{ path('app_reservation_index', { page: currentPage - 1 }) }}" class="px-4 py-2 border border-gray-300 rounded-lg text-sm text-gray-700 hover:bg-gray-50">Précédent</a>
            {% endif %}

            {% for p in 1..totalPages %}
                <a href="{{ path('app_reservation_index', { page: p }) }}"
                   class="px-4 py-2 rounded-lg text-sm {{ p == currentPage ? 'bg-gray-900 text-white' : 'border border-gray-300 text-gray-700 hover:bg-gray-50' }}">{{ p }}</a>
            {% endfor %}

            {% if currentPage < totalPages %}
                <a href="{{ path('app_reservation_index', { page: currentPage + 1 }) }}" class="px-4 py-2 border border-gray-300 rounded-lg text-sm text-gray-700 hover:bg-gray-50">Suivant</a>
            {% endif %}
        </div>
        {% endif %}
    {% else %}
        <div class="text-center py-16 text-gray-500">
            <p class="text-lg">Aucune représentation disponible pour le moment.</p>
            <p class="mt-2 text-sm">Revenez bientôt pour découvrir notre prochaine saison.</p>
        </div>
    {% endif %}
</section>
{% endblock %}
