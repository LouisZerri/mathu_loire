{% extends 'layouts/public.html.twig' %}

{% block title %}Récapitulatif - Les Mathu'Loire{% endblock %}

{% block body %}
<section class="max-w-2xl mx-auto px-4 py-12">
    {% include 'components/public/reservation_stepper.html.twig' with { currentStep: 2 } %}

    <a href="{{ path('app_reservation_new', { id: representation.id }) }}" class="text-sm text-gray-500 hover:text-gray-700 mb-6 inline-block">&larr; Modifier ma réservation</a>

    <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
        <div class="bg-gray-50 border-b border-gray-200 px-8 py-5">
            <h1 class="text-xl font-semibold text-gray-900">Récapitulatif de votre réservation</h1>
        </div>

        <div class="px-8 py-6 space-y-6">
            <div class="grid grid-cols-2 gap-6">
                <div>
                    <span class="text-xs text-gray-400 uppercase tracking-wide">Spectacle</span>
                    <p class="font-semibold text-gray-900 mt-1">{{ representation.show.title }}</p>
                </div>
                <div>
                    <span class="text-xs text-gray-400 uppercase tracking-wide">Date</span>
                    <p class="font-semibold text-gray-900 mt-1">{{ representation.datetime|format_datetime(pattern='EEEE d MMMM yyyy', locale='fr', timezone='Europe/Paris')|capitalize }}</p>
                    <p class="text-sm text-gray-500">à {{ representation.datetime|format_datetime(pattern='HH:mm', locale='fr', timezone='Europe/Paris') }}</p>
                </div>
            </div>

            <div class="border-t border-gray-100 pt-6">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-gray-100">
                            <th class="text-left font-medium text-gray-500 pb-3">Type</th>
                            <th class="text-center font-medium text-gray-500 pb-3">Qté</th>
                            <th class="text-right font-medium text-gray-500 pb-3">Prix unitaire</th>
                            <th class="text-right font-medium text-gray-500 pb-3">Sous-total</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% if draft.nbAdults > 0 %}
                        <tr class="border-b border-gray-50">
                            <td class="py-3 text-gray-900">Adulte</td>
                            <td class="py-3 text-center text-gray-900">{{ draft.nbAdults }}</td>
                            <td class="py-3 text-right text-gray-500">{{ representation.adultPrice|number_format(2, ',', ' ') }} €</td>
                            <td class="py-3 text-right font-medium text-gray-900">{{ (draft.nbAdults * representation.adultPrice)|number_format(2, ',', ' ') }} €</td>
                        </tr>
                        {% endif %}
                        {% if draft.nbChildren > 0 %}
                        <tr class="border-b border-gray-50">
                            <td class="py-3 text-gray-900">Enfant</td>
                            <td class="py-3 text-center text-gray-900">{{ draft.nbChildren }}</td>
                            <td class="py-3 text-right text-gray-500">{{ representation.childPrice|number_format(2, ',', ' ') }} €</td>
                            <td class="py-3 text-right font-medium text-gray-900">{{ (draft.nbChildren * representation.childPrice)|number_format(2, ',', ' ') }} €</td>
                        </tr>
                        {% endif %}
                    </tbody>
                </table>

                {% if draft.isPMR %}
                <p class="text-sm text-gray-500 mt-3">Personne à mobilité réduite : Oui</p>
                {% endif %}
            </div>

            <div class="bg-gray-50 -mx-8 px-8 py-5 flex justify-between items-center">
                <span class="text-base font-semibold text-gray-900">Total à payer</span>
                <span class="text-3xl font-bold text-gray-900">{{ total|number_format(2, ',', ' ') }} €</span>
            </div>

            <div class="pt-2">
                <span class="text-xs text-gray-400 uppercase tracking-wide">Vos coordonnées</span>
                <div class="mt-2 flex items-start justify-between">
                    <div>
                        <p class="font-medium text-gray-900">{{ draft.firstName }} {{ draft.lastName }}</p>
                        <p class="text-sm text-gray-500 mt-0.5">{{ draft.email }}</p>
                        <p class="text-sm text-gray-500">{{ draft.phone }}</p>
                    </div>
                    <p class="text-sm text-gray-500">{{ draft.city }}</p>
                </div>
            </div>
        </div>

        <div class="px-8 pb-8 pt-2 space-y-3">
            <a href="{{ path('app_reservation_pay', { id: representation.id }) }}"
               class="block w-full bg-gray-900 text-white py-3.5 rounded-lg text-sm font-semibold hover:bg-gray-800 transition-colors text-center">
                Payer en ligne — {{ total|number_format(2, ',', ' ') }} €
            </a>
            <p class="text-xs text-gray-400 text-center">Paiement sécurisé via HelloAsso. Une contribution à HelloAsso pourra être ajoutée.</p>

            <div class="relative flex items-center justify-center">
                <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-gray-200"></div></div>
                <span class="relative bg-white px-3 text-xs text-gray-400">ou</span>
            </div>

            <form method="post" action="{{ path('app_reservation_box_office', { id: representation.id }) }}">
                <button type="submit"
                        class="w-full border border-gray-300 text-gray-700 py-3 rounded-lg text-sm font-medium hover:bg-gray-50 transition-colors">
                    Réserver — paiement au guichet
                </button>
            </form>
            <p class="text-xs text-gray-400 text-center">Vous réglerez directement à la billetterie le soir du spectacle.</p>
        </div>
    </div>
</section>
{% endblock %}
